# =============================================================================
# Paperclip Control Center — Bootstrap .env Template
#
# Copy to .env and fill in real values.
#
# This file contains ONLY the 5 bootstrap vars that cannot live in Convex.
# All other secrets are stored in Convex via:
#   npx convex env set KEY=VALUE
#   npx convex env list
#
# One-time setup:
#   1. npx convex login
#   2. npx convex dev --once       (writes CONVEX_DEPLOYMENT to .env.local)
#   3. .\scripts\push-env-to-convex.ps1   (pushes all secrets to Convex)
#   4. Get CONVEX_DEPLOY_KEY from Convex Dashboard → Settings → Deploy Keys
# =============================================================================

# --- Bootstrap: Convex client URLs (public, non-secret) ---
# Updated by `npx convex dev` via .env.local — keep in sync
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Bootstrap: AES-256-GCM encryption key ---
# Cannot be stored inside the system it encrypts (chicken-and-egg)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRETS_ENCRYPTION_KEY=GENERATE_WITH_COMMAND_ABOVE

# --- Bootstrap: API bearer token ---
# Clients and CLI send this as: Authorization: Bearer <KEY>
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('base64url'))"
CONTROL_CENTER_API_KEY=GENERATE_WITH_COMMAND_ABOVE

# --- Bootstrap: Convex admin key ---
# Required for internal Convex functions (config.get, secrets.getEncrypted, audit.append)
# Get from: Convex Dashboard → <project> → Settings → Deploy Keys → "Deploy key"
CONVEX_DEPLOY_KEY=prod:project-slug:XXXX

# --- App ports (optional overrides) ---
API_PORT=3001
WEB_PORT=3030
