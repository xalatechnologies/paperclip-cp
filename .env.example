# =============================================================================
# Paperclip Control Center — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to version control
# =============================================================================

# --- Control Center Auth ---
# Secret key for the API (Bearer token clients must send)
CONTROL_CENTER_API_KEY=change-me-before-use

# --- Database ---
DATABASE_URL=postgresql://pcc:devpassword@localhost:5432/pcc

# --- Redis (for BullMQ worker) ---
REDIS_URL=redis://localhost:6379

# --- Paperclip API ---
# Get this from your Paperclip dashboard
PAPERCLIP_API_KEY=PLACEHOLDER
PAPERCLIP_BASE_URL=https://api.paperclip.ai

# --- Secrets Encryption ---
# 32-character hex string — generate with: openssl rand -hex 32
SECRETS_ENCRYPTION_KEY=PLACEHOLDER_32_CHAR_HEX_KEY_HERE__

# --- App URLs ---
NEXT_PUBLIC_API_URL=http://localhost:3001
API_PORT=3001
WEB_PORT=3000

# --- Slack Integration (Phase 3) ---
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=...
# SLACK_CHANNEL_ALERTS=#pcc-alerts

# --- VPS SSH (Phase 2) ---
# SSH keys are stored encrypted in the DB, not here
# VPS_DEFAULT_HOST=your-vps-ip
