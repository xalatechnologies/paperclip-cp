{
  "name": "@pcc/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":       "tsx watch --env-file=../../.env src/index.ts",
    "dev:local": "tsx watch src/index.ts",
    "build":     "tsc -p tsconfig.json",
    "start":     "node --env-file=../../.env dist/index.js",
    "test":      "vitest run",
    "lint":      "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.0",
    "@pcc/config": "workspace:*",
    "@pcc/paperclip-sdk": "workspace:*",
    "@pcc/shared-types": "workspace:*",
    "convex": "^1.40.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.0",
    "node-cron": "^4.2.1",
    "node-ssh": "^13.2.1",
    "openai": "^6.42.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
